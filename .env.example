# Server
NODE_ENV=development
PORT=3000
CORS_ORIGIN=*
APP_VERSION=0.1.0
TRUST_PROXY=0

# Database (MySQL)
# Hostinger: utilise l'hÃ´te/port fournis dans hPanel + autorise ton IP en "Remote MySQL".
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_CONNECTION_LIMIT=10
DB_DEBUG=0

# Optional SSL (selon l'hÃ©bergeur)
DB_SSL=0
DB_SSL_REJECT_UNAUTHORIZED=1
# DB_SSL_CA_PATH=C:\\path\\to\\ca.pem

# Ligue
# Le schedule est gÃ©rÃ© en base (table: ligue_settings).

# Payments
FEDAPAY_API_BASE_URL=https://api.fedapay.com/v1
FEDAPAY_SECRET_KEY=
PAYMENT_CALLBACK_BASE_URL=
PAYMENT_PREMIUM_AMOUNT=375
PAYMENT_PREMIUM_DESCRIPTION=Abonnement mensuel
PAYMENT_CURRENCY_ISO=XOF
PAYMENT_DURATION_DAYS=30

# Admin dashboard
ADMIN_DASHBOARD_TITLE=iShiine Admin
ADMIN_ACCESS_TOKEN_SECRET=change_me_admin_access_secret
ADMIN_ACCESS_TOKEN_TTL_MINUTES=15
ADMIN_REFRESH_TOKEN_TTL_DAYS=30
ADMIN_COOKIE_SECURE=false
ADMIN_COOKIE_DOMAIN=



# Firebase push
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_BASE64=
FIREBASE_SERVICE_ACCOUNT_PATH=

# Notification jobs
NOTIFICATION_JOBS_ENABLED=0
NOTIFICATION_JOBS_INTERVAL_SECONDS=60
SUBSCRIPTION_EXPIRY_REMINDER_HOURS=24
SUBSCRIPTION_EXPIRED_LOOKBACK_HOURS=48
