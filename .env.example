# Server
NODE_ENV=development
PORT=3000
CORS_ORIGIN=*
APP_VERSION=0.1.0
TRUST_PROXY=0

# Database (MySQL)
# Hostinger: utilise l'hôte/port fournis dans hPanel + autorise ton IP en "Remote MySQL".
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_CONNECTION_LIMIT=10
DB_DEBUG=0

# Optional SSL (selon l'hébergeur)
DB_SSL=0
DB_SSL_REJECT_UNAUTHORIZED=1
# DB_SSL_CA_PATH=C:\\path\\to\\ca.pem

# Ligue
# Le schedule est géré en base (table: ligue_settings).
