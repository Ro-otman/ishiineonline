<%- include('partials/layout-start') %>

<% const pm = data.paymentMetrics || {}; %>
<% const testTarget = data.notificationTestTarget || null; %>

<section class="hero-band global-hero">
  <div class="hero-copy hero-copy-featured">
    <div class="hero-copy-head">
      <span class="hero-emblem"><i class="bx bxs-dashboard"></i></span>
      <div>
        <p class="eyebrow">Vue d’ensemble</p>
        <h3>Suivi global d’iShiine</h3>
      </div>
    </div>
    <p class="hero-summary">Utilisateurs, revenus, contenu et activité récente.</p>
    <div class="hero-mini-points">
      <span class="hero-mini-pill"><i class="bx bx-user"></i> Utilisateurs</span>
      <span class="hero-mini-pill"><i class="bx bx-wallet-alt"></i> Revenus</span>
      <span class="hero-mini-pill"><i class="bx bx-book-open"></i> Contenu</span>
      <span class="hero-mini-pill"><i class="bx bx-pulse"></i> Activité</span>
    </div>
  </div>

  <div class="hero-highlight">
    <div class="hero-score">
      <span>Chiffre d’affaires confirmé</span>
      <strong><%= helpers.money(pm.grossRevenue || 0) %> F CFA</strong>
      <small><%= helpers.number(pm.successfulPayments || 0) %> paiement(s) validé(s)</small>
    </div>
    <div class="hero-badges">
      <span class="soft-badge"><i class="bx bx-wallet"></i> Mois en cours <%= helpers.money(pm.monthRevenue || 0) %> F CFA</span>
      <span class="soft-badge"><i class="bx bx-transfer-alt"></i> Déjà transféré <%= helpers.money(pm.transferredRevenue || 0) %> F CFA</span>
      <span class="soft-badge"><i class="bx bx-line-chart"></i> Score moyen <%= data.metrics.averageScore %>%</span>
    </div>
  </div>
</section>

<section class="metric-grid metric-grid-6 dashboard-metrics">
  <article class="metric-card panel metric-with-icon">
    <div class="metric-topline">
      <div class="metric-icon metric-icon-sky"><i class="bx bxs-user"></i></div>
      <span class="metric-label">Utilisateurs</span>
    </div>
    <div class="metric-body">
      <strong class="metric-value"><%= helpers.number(data.metrics.totalUsers) %></strong>
      <span class="metric-help">Comptes créés</span>
    </div>
  </article>

  <article class="metric-card panel metric-with-icon accent-sky">
    <div class="metric-topline">
      <div class="metric-icon metric-icon-blue"><i class="bx bxs-badge-check"></i></div>
      <span class="metric-label">Abonnés actifs</span>
    </div>
    <div class="metric-body">
      <strong class="metric-value"><%= helpers.number(data.metrics.activeSubscribers) %></strong>
      <span class="metric-help">Premium en cours</span>
    </div>
  </article>

  <article class="metric-card panel metric-with-icon accent-gold">
    <div class="metric-topline">
      <div class="metric-icon metric-icon-gold"><i class="bx bxs-bank"></i></div>
      <span class="metric-label">CA confirmé</span>
    </div>
    <div class="metric-body">
      <strong class="metric-value"><%= helpers.money(pm.grossRevenue || 0) %></strong>
      <span class="metric-help">Paiements approuvés ou transférés</span>
    </div>
  </article>

  <article class="metric-card panel metric-with-icon accent-coral">
    <div class="metric-topline">
      <div class="metric-icon metric-icon-coral"><i class="bx bxs-calendar-star"></i></div>
      <span class="metric-label">CA du mois</span>
    </div>
    <div class="metric-body">
      <strong class="metric-value"><%= helpers.money(pm.monthRevenue || 0) %></strong>
      <span class="metric-help">Lecture mensuelle</span>
    </div>
  </article>

  <article class="metric-card panel metric-with-icon accent-mint">
    <div class="metric-topline">
      <div class="metric-icon metric-icon-mint"><i class="bx bxs-book-content"></i></div>
      <span class="metric-label">Quiz publiés</span>
    </div>
    <div class="metric-body">
      <strong class="metric-value"><%= helpers.number(data.metrics.totalQuiz) %></strong>
      <span class="metric-help"><%= helpers.number(data.metrics.totalSa) %> SA et <%= helpers.number(data.metrics.totalProgrammes) %> programmes</span>
    </div>
  </article>

  <article class="metric-card panel metric-with-icon accent-violet">
    <div class="metric-topline">
      <div class="metric-icon metric-icon-violet"><i class="bx bxs-edit-alt"></i></div>
      <span class="metric-label">Tentatives</span>
    </div>
    <div class="metric-body">
      <strong class="metric-value"><%= helpers.number(data.metrics.totalAttempts) %></strong>
      <span class="metric-help">Activité globale des apprenants</span>
    </div>
  </article>
</section>

<section class="content-grid-2 dashboard-grid">
  <article class="panel form-panel content-form-panel">
    <div class="section-head content-section-head">
      <div>
        <p class="eyebrow"><i class="bx bx-bell"></i> Notification test</p>
        <h3><i class="bx bx-paper-plane"></i> Envoyer un push systeme</h3>
      </div>
      <span class="soft-badge"><i class="bx bx-devices"></i> Test rapide</span>
    </div>

    <form method="post" action="/admin/notifications/test-push" class="quiz-form notification-test-form">
      <label class="content-field">
        <span class="content-field-label"><i class="bx bx-rename"></i> Titre</span>
        <input type="text" name="title" value="iShiine ✓ Test" maxlength="120" />
      </label>

      <label class="content-field">
        <span class="content-field-label"><i class="bx bx-message-rounded-detail"></i> Message</span>
        <textarea name="message" rows="3">Ceci est une notification de test envoyée depuis l’admin.</textarea>
      </label>

      <% if (testTarget) { %>
        <input type="hidden" name="userId" value="<%= testTarget.id_user %>" />
        <article class="spotlight-card">
          <span class="spotlight-icon"><i class="bx bx-mobile-alt"></i></span>
          <div>
            <strong><%= testTarget.display_name %></strong>
            <p>Dernier appareil actif<% if (testTarget.platform) { %> • <%= testTarget.platform %><% } %><% if (testTarget.updated_at) { %> • <%= helpers.dateTime(testTarget.updated_at) %><% } %></p>
          </div>
        </article>
      <% } else { %>
        <p class="empty-copy">Aucun appareil actif détecté. Ouvre l’app sur le téléphone, connecte-toi et laisse Internet actif.</p>
      <% } %>

      <button type="submit" class="primary-button" <%= testTarget ? '' : 'disabled' %>>
        <i class="bx bx-send"></i> Envoyer la notification test
      </button>
    </form>
  </article>

  <article class="panel">
    <div class="section-head">
      <div>
        <p class="eyebrow">Verification</p>
        <h3>Ce qu'on doit voir</h3>
      </div>
    </div>

    <div class="spotlight-grid">
      <article class="spotlight-card">
        <span class="spotlight-icon"><i class="bx bx-wifi"></i></span>
        <div>
          <strong>Telephone connecte</strong>
          <p>Le mobile doit avoir Internet et les notifications autorisees.</p>
        </div>
      </article>

      <article class="spotlight-card">
        <span class="spotlight-icon"><i class="bx bx-window-open"></i></span>
        <div>
          <strong>Banniere systeme</strong>
          <p>En arriere-plan ou ecran verrouille, la notification doit apparaitre en haut comme d'habitude.</p>
        </div>
      </article>

      <article class="spotlight-card">
        <span class="spotlight-icon"><i class="bx bx-refresh"></i></span>
        <div>
          <strong>Si rien n'arrive</strong>
          <p>On saura alors que le souci vient plutot du token Firebase ou de la build installee sur le telephone.</p>
        </div>
      </article>
    </div>
  </article>
</section>

<section class="content-grid-2 dashboard-grid">
  <article class="panel spotlight-panel">
    <div class="section-head">
      <div>
        <p class="eyebrow">Monétisation</p>
        <h3>État du premium</h3>
      </div>
      <a class="ghost-link" href="/admin/payments">Ouvrir le journal</a>
    </div>

    <div class="spotlight-grid">
      <article class="spotlight-card spotlight-card-strong">
        <span class="spotlight-icon"><i class="bx bxs-credit-card-front"></i></span>
        <div>
          <strong><%= helpers.number(pm.totalPayments || 0) %> transaction(s)</strong>
          <p>Vue rapide du flux de paiements.</p>
        </div>
      </article>

      <article class="spotlight-card">
        <span class="spotlight-icon"><i class="bx bx-loader-circle"></i></span>
        <div>
          <strong><%= helpers.number(pm.pendingPayments || 0) %> en attente</strong>
          <p>Paiements à vérifier.</p>
        </div>
      </article>

      <article class="spotlight-card">
        <span class="spotlight-icon"><i class="bx bx-x-circle"></i></span>
        <div>
          <strong><%= helpers.number(pm.failedPayments || 0) %> échec(s)</strong>
          <p>Paiements non aboutis.</p>
        </div>
      </article>
    </div>
  </article>

  <article class="panel insight-panel panel-class-breakdown">
    <div class="section-head">
      <div>
        <p class="eyebrow">Répartition</p>
        <h3>Classes les plus présentes</h3>
      </div>
    </div>

    <div class="insight-grid class-breakdown-list">
      <% data.classBreakdown.forEach((item) => { %>
        <article class="insight-tile insight-class-tile">
          <div class="insight-class-top">
            <span class="insight-class-icon"><i class="bx bxs-school"></i></span>
            <span class="insight-class-tag">Classe</span>
          </div>
          <div class="insight-class-row">
            <strong class="insight-class-name"><%= item.classe %></strong>
            <span class="insight-class-count"><%= helpers.number(item.total) %> compte(s)</span>
          </div>
        </article>
      <% }) %>
    </div>
  </article>
</section>

