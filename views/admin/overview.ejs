<section class="content-grid-2 dashboard-grid">  <article class="panel">
    <div class="section-head">
      <div>
        <p class="eyebrow">Paiements récents</p>
        <h3>Dernières transactions</h3>
      </div>
      <span class="soft-badge"><i class="bx bx-receipt"></i> <%= helpers.number(pm.totalPayments || 0) %> transaction(s)</span>
    </div>

    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Transaction</th>
            <th>Utilisateur</th>
            <th>Montant</th>
            <th>Statut</th>
          </tr>
        </thead>
        <tbody>
          <% if (!data.recentPayments.length) { %>
            <tr><td colspan="4">Aucune transaction enregistrée pour le moment.</td></tr>
          <% } %>
          <% data.recentPayments.forEach((payment) => { %>
            <% const displayName = `${payment.prenoms || payment.customer_firstname || ''} ${payment.nom || payment.customer_lastname || ''}`.trim() || 'Utilisateur inconnu'; %>
            <% const displayEmail = payment.user_email || payment.customer_email || payment.customer_phone || 'Aucun contact'; %>
            <tr>
              <td>
                <strong><%= payment.transaction_id %></strong>
                <small><%= helpers.dateTime(payment.provider_updated_at || payment.updated_at || payment.created_at) %></small>
              </td>
              <td>
                <strong><%= displayName %></strong>
                <small><%= displayEmail %></small>
              </td>
              <td>
                <strong><%= helpers.money(payment.amount) %> <%= payment.currency_iso || 'XOF' %></strong>
              <small><%= payment.classe || 'Classe non renseignée' %></small>
              </td>
              <td>
                <span class="status-pill <%= ['approved', 'transferred'].includes(String(payment.status || '').toLowerCase()) ? 'status-pill-active' : 'status-pill-idle' %>">
                  <i class="bx <%= ['approved', 'transferred'].includes(String(payment.status || '').toLowerCase()) ? 'bx-check-shield' : 'bx-time-five' %>"></i>
                  <%= payment.status || 'inconnu' %>
                </span>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </article>

  <article class="panel">
    <div class="section-head">
      <div>
        <p class="eyebrow">Utilisateurs récents</p>
        <h3>Nouveaux comptes</h3>
      </div>
      <a class="ghost-link" href="/admin/users">Voir les comptes</a>
    </div>

    <div class="stack-list">
      <% if (!data.recentUsers.length) { %><p class="empty-copy">Aucun utilisateur pour le moment.</p><% } %>
      <% data.recentUsers.forEach((user) => { %>
        <article class="list-card polished-list-card">
          <div class="list-persona">
            <span class="avatar-chip"><i class="bx bx-user"></i></span>
            <div>
              <strong><%= `${user.prenoms} ${user.nom}` %></strong>
              <small><%= user.email || user.phone || 'Contact non renseigné' %></small>
            </div>
          </div>
          <div class="list-meta">
            <span class="status-pill <%= Number(user.is_subscribed) === 1 ? 'status-pill-active' : 'status-pill-idle' %>">
              <i class="bx <%= Number(user.is_subscribed) === 1 ? 'bx-star' : 'bx-circle' %>"></i>
              <%= Number(user.is_subscribed) === 1 ? 'Abonné' : 'Libre' %>
            </span>
            <small><%= user.classe %></small>
          </div>
        </article>
      <% }) %>
    </div>
  </article>
</section>

